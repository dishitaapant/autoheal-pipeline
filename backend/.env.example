# AutoHeal Backend Environment Variables
# Copy this file to .env and fill in your values

MONGO_URL=mongodb://localhost:27017
DB_NAME=autoheal

# GitHub personal access token with repo + actions permissions
GITHUB_TOKEN=ghp_your_token_here

# Webhook secret set in GitHub repo settings
WEBHOOK_SECRET=your_webhook_secret_here

# Retry configuration
MAX_RETRIES=3
RETRY_BASE_DELAY=2.0

# ML model storage
MODEL_PATH=/tmp/autoheal_model.pkl

# Server
PORT=8000
HOST=0.0.0.0
